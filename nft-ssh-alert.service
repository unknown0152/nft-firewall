[Unit]
Description=NFT Firewall SSH Alert — intrusion notifier
After=network-online.target fail2ban.service
Wants=network-online.target fail2ban.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/fw-admin/nft-firewall/src/main.py ssh-alert daemon
Restart=always
RestartSec=15
User=root
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nft-ssh-alert

[Install]
WantedBy=multi-user.target
