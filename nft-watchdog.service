[Unit]
Description=NFT Firewall Watchdog — WireGuard VPN health monitor
After=network-online.target wg-quick@wg0.service
Wants=network-online.target
Requires=wg-quick@wg0.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /home/fw-admin/nft-firewall/src/main.py watchdog daemon
Restart=always
RestartSec=10
User=root
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nft-watchdog

[Install]
WantedBy=multi-user.target
